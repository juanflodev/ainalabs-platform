@page "/analizador"
@rendermode InteractiveServer
@using AinaLabs.Infrastructure
@using NodusLab.Core.Interfaces
@using NodusLab.Core.Models
@using NodusLab.Infrastructure

@inject AinaDbContext DbContext
@inject AiEngineClient AiClient
@inject ITenantService TenantService

<PageTitle>Analizador de Contratos - AinaLabs</PageTitle>

<div class="max-w-4xl mx-auto p-6 font-sans">
    <h1 class="text-3xl font-bold mb-2">Analizador Legal con IA</h1>
    <p class="text-gray-600 mb-8">Sube un contrato y nuestra IA extraerá los riesgos clave basándose en el contexto de tu empresa.</p>

    <div class="bg-white p-6 rounded-lg shadow-md border border-gray-200">
        <button @onclick="ProcesarDocumento" disabled="@_isProcessing" 
                class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 disabled:bg-gray-400">
            @if (_isProcessing)
            {
                <span>Analizando con IA (puede tardar unos segundos)...</span>
            }
            else
            {
                <span>Simular Subida y Análisis de PDF</span>
            }
        </button>

        @if (_resultado != null)
        {
            <div class="mt-8 p-4 bg-green-50 border border-green-200 rounded">
                <h3 class="font-bold text-green-800 text-lg">✅ Análisis Completado</h3>
                
                <h4 class="font-semibold mt-4">Resumen del Documento:</h4>
                <p class="text-gray-700">@_resultado.summary</p>

                <h4 class="font-semibold mt-4">Riesgos Detectados:</h4>
                <ul class="list-disc pl-5 mt-2">
                    @foreach (var riesgo in _resultado.key_findings)
                    {
                        <li class="mb-2">
                            <span class="font-bold text-red-600">[@riesgo.risk_level.ToUpper()]</span> 
                            <strong>@riesgo.topic:</strong> @riesgo.description
                        </li>
                    }
                </ul>
            </div>
        }
    </div>
</div>

@code {
    private bool _isProcessing = false;
    private AnalysisResult? _resultado;

    private async Task ProcesarDocumento()
    {
        _isProcessing = true;
        _resultado = null;
        StateHasChanged(); // Forzamos a que Blazor pinte el estado de "Cargando..."

        try
        {
            // 1. Obtenemos el ID de la empresa actual (El Mock que hicimos)
            var currentTenantId = TenantService.GetTenantId();

            // 2. Guardamos el registro del documento en PostgreSQL
            var nuevoDocumento = new Document
            {
                TenantId = currentTenantId,
                FileName = $"contrato_confidencial_{DateTime.Now.Ticks}.pdf",
                Status = "processing"
            };

            DbContext.Documents.Add(nuevoDocumento);
            // AQUÍ OCURRE LA MAGIA DEL RLS: Entity Framework inyectará el SET app.current_tenant
            await DbContext.SaveChangesAsync(); 

            // 3. Preparamos la petición para enviar a Python
            var request = new AnalyzePdfRequest(
                tenant_id: currentTenantId.ToString(),
                user_id: "user_demo_123",
                file_metadata: new FileMetadata(nuevoDocumento.Id.ToString(), nuevoDocumento.FileName, "/rutas/simuladas/file.pdf"),
                analysis_config: new AnalysisConfig("es", "legal_risk", true)
            );

            // 4. Llamamos al microservicio de Python
            var response = await AiClient.AnalyzePdfAsync(request);

            if (response != null && response.status == "success")
            {
                // 5. Actualizamos el estado en base de datos
                nuevoDocumento.Status = "ready";
                await DbContext.SaveChangesAsync();

                // 6. Mostramos el resultado en pantalla
                _resultado = response.analysis_result;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
            // Aquí iría un mensaje de error para el usuario
        }
        finally
        {
            _isProcessing = false;
        }
    }
}